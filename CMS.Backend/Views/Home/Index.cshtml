@model IEnumerable<CMS.Data.Entities.Post>
@{
    ViewData["Title"] = "Home Page";
    Layout = "_LayoutAdmin";

}

<div class="container mt-5">
    <h2 class="text-center mb-4 text-danger">TIN TỨC MỚI NHẤT</h2>
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <img src="@item.ImageUrl"
                         class="card-img-top"
                         style="height:180px; object-fit:cover;"
                         onerror="this.src='https://via.placeholder.com/300x180?text=No+Image'"
                         alt="Thumbnail">
                    <div class="card-body">
                        <span class="badge bg-primary mb-2">
                            @(item.Category?.Name ?? "Chưa phân loại")
                        </span>
                        <h5 class="card-title mt-1">@item.Title</h5>
                        <p class="card-text text-truncate text-muted small">
                            @item.Content
                        </p>
                        <a href="/Post/Details/@item.Id"
                           class="btn btn-outline-danger btn-sm">
                            Đọc tiếp →
                        </a>
                    </div>
                    <div class="card-footer text-muted small">
                        📅 @item.CreatedDate.ToString("dd/MM/yyyy")
                    </div>
                </div>
            </div>
        }
    </div>
</div>