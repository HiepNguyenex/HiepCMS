@model IEnumerable<CMS.Data.Entities.Order>
@{
    ViewData["Title"] = "Đơn hàng";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-warning mb-0">🧾 DANH SÁCH ĐƠN HÀNG</h2>
    </div>

    <!-- BỘ LỌC TRẠNG THÁI -->
    <div class="mb-4">
        <div class="btn-group" role="group" aria-label="Order Status Filter">
            <a href="@Url.Action("Index")" class="btn @(ViewBag.CurrentFilter == -1 ? "btn-dark" : "btn-outline-dark")">Tất cả</a>
            <a href="@Url.Action("Index", new { status = 0 })" class="btn @(ViewBag.CurrentFilter == 0 ? "btn-warning text-dark" : "btn-outline-warning text-dark")">Chờ xác nhận</a>
            <a href="@Url.Action("Index", new { status = 1 })" class="btn @(ViewBag.CurrentFilter == 1 ? "btn-primary" : "btn-outline-primary")">Đang xử lý</a>
            <a href="@Url.Action("Index", new { status = 2 })" class="btn @(ViewBag.CurrentFilter == 2 ? "btn-success" : "btn-outline-success")">Đã giao</a>
            <a href="@Url.Action("Index", new { status = 3 })" class="btn @(ViewBag.CurrentFilter == 3 ? "btn-danger" : "btn-outline-danger")">Đã hủy</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3" style="width: 5%;">#</th>
                            <th style="width: 15%;">Khách hàng</th>
                            <th style="width: 15%;">Ngày đặt</th>
                            <th style="width: 15%;">Tổng tiền</th>
                            <th style="width: 20%;">Trạng thái cập nhật</th>
                            <th style="width: 15%;">Ghi chú</th>
                            <th class="text-center" style="width: 15%;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">Chưa có đơn hàng nào trong hệ thống.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-3 align-middle">@item.Id</td>
                                    <td class="align-middle fw-semibold">@(item.Customer?.FullName ?? $"Khách hàng #{item.CustomerId}")</td>
                                    <td class="align-middle text-nowrap">@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="align-middle fw-bold text-danger text-nowrap">
                                        @((item.OrderDetails?.Sum(d => d.Quantity * d.UnitPrice) ?? 0).ToString("N0")) đ
                                    </td>
                                    <td class="align-middle">
                                        <form asp-action="UpdateStatus" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <select name="status" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
                                                <option value="0" selected="@(item.Status == 0)">Chờ xác nhận</option>
                                                <option value="1" selected="@(item.Status == 1)">Đang xử lý</option>
                                                <option value="2" selected="@(item.Status == 2)">Đã giao</option>
                                                <option value="3" selected="@(item.Status == 3)">Đã hủy</option>
                                            </select>
                                        </form>
                                    </td>
                                    <td class="align-middle text-muted text-truncate" style="max-width: 150px;">@(item.Notes ?? "-")</td>
                                    <td class="align-middle text-center">
                                        <div class="btn-group" role="group">
                                            <button type="button" class="btn btn-sm btn-outline-primary btn-view-details" data-order-id="@item.Id" title="Xem chi tiết">
                                                <i class="bi bi-eye"></i> Xem
                                            </button>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn hủy/xóa đơn hàng này?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Hủy/Xóa">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Chi tiết Đơn hàng -->
<div class="modal fade" id="orderDetailsModal" tabindex="-1" aria-labelledby="orderDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-warning text-dark py-3">
                <h5 class="modal-title fw-bold" id="orderDetailsModalLabel">🧾 CHI TIẾT ĐƠN HÀNG</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="modal-body-content">
                <!-- Nội dung tải động qua AJAX -->
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.btn-view-details').click(function() {
                var orderId = $(this).data('order-id');
                
                // Hiển thị vòng xoay đang tải
                $('#modal-body-content').html('<div class="text-center py-4"><div class="spinner-border text-warning" role="status"></div><p class="mt-2 text-muted">Đang tải thông tin đơn hàng...</p></div>');
                $('#orderDetailsModal').modal('show');
                
                // Gọi AJAX lấy dữ liệu từ Web API chúng ta đã định nghĩa
                $.ajax({
                    url: '/api/orders/' + orderId,
                    type: 'GET',
                    dataType: 'json',
                    success: function(data) {
                        var statusText = '';
                        var statusBadge = '';
                        switch(data.status) {
                            case 0:
                                statusText = 'Chờ xác nhận';
                                statusBadge = 'bg-secondary';
                                break;
                            case 1:
                                statusText = 'Đang xử lý';
                                statusBadge = 'bg-warning text-dark';
                                break;
                            case 2:
                                statusText = 'Đã giao';
                                statusBadge = 'bg-success';
                                break;
                            case 3:
                                statusText = 'Đã hủy';
                                statusBadge = 'bg-danger';
                                break;
                            default:
                                statusText = 'Không rõ';
                                statusBadge = 'bg-light text-dark';
                        }
                        
                        var date = new Date(data.orderDate);
                        var formattedDate = date.getDate().toString().padStart(2, '0') + '/' + 
                                            (date.getMonth() + 1).toString().padStart(2, '0') + '/' + 
                                            date.getFullYear() + ' ' + 
                                            date.getHours().toString().padStart(2, '0') + ':' + 
                                            date.getMinutes().toString().padStart(2, '0');
                                            
                        var html = `
                            <div class="row mb-3">
                                <div class="col-md-6 mb-3 mb-md-0">
                                    <h6 class="text-warning border-bottom pb-2 fw-bold"><i class="bi bi-person-fill"></i> Khách hàng & Giao hàng</h6>
                                    <p class="mb-1"><strong>Họ tên:</strong> ${data.customerName || 'Khách hàng #' + data.customerId}</p>
                                    <p class="mb-1"><strong>Điện thoại:</strong> ${data.customerPhone || '-'}</p>
                                    <p class="mb-1"><strong>Email:</strong> ${data.customerEmail || '-'}</p>
                                    <p class="mb-1"><strong>Địa chỉ:</strong> ${data.customerAddress || '-'}</p>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="text-warning border-bottom pb-2 fw-bold"><i class="bi bi-info-circle-fill"></i> Thông tin đơn hàng</h6>
                                    <p class="mb-1"><strong>Mã đơn hàng:</strong> #${data.id}</p>
                                    <p class="mb-1"><strong>Ngày đặt:</strong> ${formattedDate}</p>
                                    <p class="mb-1"><strong>Trạng thái:</strong> <span class="badge ${statusBadge}">${statusText}</span></p>
                                    <p class="mb-1"><strong>Ghi chú:</strong> ${data.notes || '-'}</p>
                                </div>
                            </div>
                            
                            <h6 class="text-warning border-bottom pb-2 mt-4 fw-bold"><i class="bi bi-cart-fill"></i> Sản phẩm đã mua</h6>
                            <table class="table table-bordered table-striped align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th>#</th>
                                        <th>Tên sản phẩm</th>
                                        <th class="text-center">Số lượng</th>
                                        <th class="text-end">Đơn giá</th>
                                        <th class="text-end">Thành tiền</th>
                                        <th class="text-center">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                        `;
                        
                        var totalAmount = 0;
                        if(data.details && data.details.length > 0) {
                            $.each(data.details, function(index, item) {
                                html += `
                                    <tr>
                                        <td>${index + 1}</td>
                                        <td class="fw-semibold">${item.productName || 'Sản phẩm #' + item.productId}</td>
                                        <td class="text-center">${item.quantity}</td>
                                        <td class="text-end">${item.unitPrice.toLocaleString('vi-VN')} đ</td>
                                        <td class="text-end fw-bold">${item.totalPrice.toLocaleString('vi-VN')} đ</td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-outline-danger btn-delete-detail" data-detail-id="${item.id}" data-order-id="${data.id}" title="Xóa sản phẩm này">
                                                <i class="bi bi-trash"></i> Xóa
                                            </button>
                                        </td>
                                    </tr>
                                `;
                                totalAmount += item.totalPrice;
                            });
                        } else {
                            html += `<tr><td colspan="6" class="text-center text-muted">Không có chi tiết sản phẩm.</td></tr>`;
                        }
                        
                        html += `
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <th colspan="4" class="text-end py-3">Tổng giá trị đơn hàng:</th>
                                        <th class="text-end text-danger fs-5 py-3">${totalAmount.toLocaleString('vi-VN')} đ</th>
                                        <th></th>
                                    </tr>
                                </tfoot>
                            </table>
                        `;
                        
                        $('#modal-body-content').html(html);
                    },
                    error: function() {
                        $('#modal-body-content').html('<div class="alert alert-danger"><i class="bi bi-x-circle-fill"></i> Lỗi! Không thể tải dữ liệu chi tiết từ server.</div>');
                    }
                });
            });

            // Sự kiện click nút xóa chi tiết sản phẩm lỗi
            $(document).on('click', '.btn-delete-detail', function() {
                var detailId = $(this).data('detail-id');
                var orderId = $(this).data('order-id');
                
                if (confirm('Bạn có chắc chắn muốn xóa sản phẩm này khỏi đơn hàng? Số lượng tồn kho sản phẩm sẽ được hoàn trả lại.')) {
                    $.ajax({
                        url: '/api/orderdetails/' + detailId,
                        type: 'DELETE',
                        success: function(response) {
                            alert('Xóa sản phẩm khỏi đơn hàng thành công!');
                            // Load lại chi tiết đơn hàng bằng cách kích hoạt click lại nút Xem để cập nhật modal
                            $('button.btn-view-details[data-order-id="' + orderId + '"]').click();
                        },
                        error: function(xhr) {
                            var errMsg = 'Có lỗi xảy ra khi xóa sản phẩm.';
                            if (xhr.responseJSON && xhr.responseJSON.message) {
                                errMsg = xhr.responseJSON.message;
                            }
                            alert(errMsg);
                        }
                    });
                }
            });
        });
    </script>
}