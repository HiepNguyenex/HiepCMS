@model CMS.Data.Entities.Ingredient
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa nốt hương";
}

<div class="card shadow">
    <div class="card-header bg-warning text-dark">
        <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square"></i> CHỈNH SỬA NỐT HƯƠNG</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <div class="row">
                
                <!-- CỘT TRÁI -->
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tiêu đề nốt hương:</label>
                        <input asp-for="Title" class="form-control"
                               placeholder="Nhập tiêu đề nốt hương (ví dụ: Gỗ Đàn Hương)..." required />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả nốt hương:</label>
                        <textarea asp-for="Description" class="form-control"
                                  rows="5" placeholder="Mô tả chi tiết hương vị, cảm xúc mang lại..." required></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>

                <!-- CỘT PHẢI -->
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Ảnh hiện tại:</label>
                        <div class="mb-2">
                            <img src="@Model.ImageUrl"
                                 style="max-height:150px; object-fit:cover; width:100%; border-radius:6px;"
                                 onerror="this.src='https://via.placeholder.com/150?text=No+Img'"
                                 alt="@Model.Title" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Thay thế bằng upload ảnh mới:</label>
                        <input type="file" name="uploadImage" class="form-control"
                               accept="image/*"
                               onchange="previewImage(this)" />
                    </div>
                    <div class="mb-3" id="previewBox" style="display:none;">
                        <label class="form-label fw-bold">Xem trước ảnh mới:</label>
                        <img id="previewImg" src=""
                             class="img-fluid rounded"
                             style="max-height:150px; object-fit:cover; width:100%;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Hoặc chỉnh sửa link ảnh trực tiếp (URL):</label>
                        <input asp-for="ImageUrl" class="form-control"
                               placeholder="https://... hoặc /sandalwood.jpg" />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                    </div>
                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-warning fw-bold text-dark">
                            <i class="bi bi-save"></i> Lưu thay đổi
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>
                    </div>
                </div>

            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('previewImg').src = e.target.result;
                    document.getElementById('previewBox').style.display = 'block';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
