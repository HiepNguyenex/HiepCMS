@model CMS.Data.Entities.Post
@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4" style="max-width:800px">

    <!-- Ảnh bài viết -->
    <img src="@Model.ImageUrl"
         class="img-fluid rounded mb-4 w-100"
         style="max-height:400px; object-fit:cover;"
         onerror="this.src='https://via.placeholder.com/800x400?text=No+Image'">

    <!-- Badge danh mục -->
    <span class="badge bg-info text-dark mb-2">
        @(Model.Category?.Name ?? "Chưa phân loại")
    </span>

    <!-- Tiêu đề -->
    <h1 class="text-primary mt-2">@Model.Title</h1>

    <!-- Ngày đăng -->
    <p class="text-muted small">
        📅 Ngày đăng: @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
    </p>

    <hr />

    <!-- Nội dung — dùng Html.Raw để render đúng nếu dùng CKEditor sau -->
    <div class="mt-3" style="line-height:1.8; font-size:1.05rem;">
        @Html.Raw(Model.Content)
    </div>

    <hr />

    <!-- Nút quay lại -->
    <a asp-action="Index" class="btn btn-outline-secondary mt-2">
        ← Quay lại danh sách
    </a>
</div>