@model IEnumerable<CMS.Data.Entities.Post>
@{
    ViewData["Title"] = "Bài viết";
    Layout = "_LayoutAdmin";
    var categoryName = ViewBag.CategoryName as string;
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            @if (categoryName != null)
            {
                <h2 class="mb-0 text-danger">BÀI VIẾT DANH MỤC: @categoryName.ToUpper()</h2>
                <a href="/Post" class="btn btn-outline-secondary btn-sm mt-2">← Xem tất cả</a>
            }
            else
            {
                <h2 class="mb-0 text-danger">DANH SÁCH BÀI VIẾT MỚI NHẤT</h2>
            }
        </div>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm bài viết mới
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <img src="@item.ImageUrl"
                         class="card-img-top"
                         alt="@item.Title"
                         style="height:200px; object-fit:cover;"
                         onerror="this.src='https://via.placeholder.com/400x200?text=No+Image'">
                    <div class="card-body">
                        <a href="/Post/ListByCategory/@item.CategoryId"
                           class="badge bg-info text-dark mb-2 text-decoration-none">
                            @(item.Category?.Name ?? "Chưa phân loại")
                        </a>
                        <h5 class="card-title text-primary">@item.Title</h5>
                        <p class="card-text text-truncate">@item.Content</p>
                        <p class="text-muted small">
                            📅 Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")
                        </p>
                    </div>
                    <div class="card-footer d-flex gap-1">
                        <a href="/Post/Details/@item.Id"
                           class="btn btn-outline-primary btn-sm flex-fill">
                            <i class="bi bi-eye"></i> Xem
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-warning flex-fill">
                            <i class="bi bi-pencil"></i> Sửa
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-danger flex-fill"
                           onclick="return confirm('Xóa bài viết này?')">
                            <i class="bi bi-trash"></i> Xóa
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

@* ───────── PAGINATION ───────── *@
@{
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string baseUrl = categoryName != null ? "/Post/ListByCategory/" + ViewContext.RouteData.Values["id"] : "/Post";
}
@if (totalPages > 1)
{
    <nav aria-label="Phân trang bài viết">
        <ul class="pagination justify-content-center mt-4">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="@baseUrl?page=@(currentPage - 1)&pageSize=9">‹</a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="@baseUrl?page=@i&pageSize=9">@i</a>
                </li>
            }
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" href="@baseUrl?page=@(currentPage + 1)&pageSize=9">›</a>
            </li>
        </ul>
        <p class="text-center text-muted small mb-0">
            Trang @currentPage / @totalPages (tổng số @ViewBag.TotalItems bài viết)
        </p>
    </nav>
}

</div>