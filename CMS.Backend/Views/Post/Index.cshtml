@model IEnumerable<CMS.Data.Entities.Post>
@{
    ViewData["Title"] = "Bài viết";
    var categoryName = ViewBag.CategoryName as string;
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            @if (categoryName != null)
            {
                <h2 class="mb-0 text-danger">BÀI VIẾT DANH MỤC: @categoryName.ToUpper()</h2>
                <a href="/Post" class="btn btn-outline-secondary btn-sm mt-2">← Xem tất cả</a>
            }
            else
            {
                <h2 class="mb-0 text-danger">DANH SÁCH BÀI VIẾT MỚI NHẤT</h2>
            }
        </div>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <img src="@item.ImageUrl"
                         class="card-img-top"
                         alt="@item.Title"
                         style="height:200px; object-fit:cover;"
                         onerror="this.src='https://via.placeholder.com/400x200?text=No+Image'">
                    <div class="card-body">
                        <a href="/Post/ListByCategory/@item.CategoryId"
                           class="badge bg-info text-dark mb-2 text-decoration-none">
                            @(item.Category?.Name ?? "Chưa phân loại")
                        </a>
                        <h5 class="card-title text-primary">@item.Title</h5>
                        <p class="card-text text-truncate">@item.Content</p>
                        <p class="text-muted small">
                            📅 Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")
                        </p>
                    </div>
                    <div class="card-footer d-flex gap-1">
                        <a href="/Post/Details/@item.Id"
                           class="btn btn-outline-primary btn-sm w-100">
                            <i class="bi bi-eye"></i> Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

</div>