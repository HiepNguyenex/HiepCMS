@model CMS.Data.Entities.Post
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Sửa bài viết";
}

<div class="card shadow">
    <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="bi bi-pencil-square"></i> SỬA BÀI VIẾT</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">

            <!-- ⚠️ BẮT BUỘC: giữ Id để biết đang sửa bài nào -->
            <input type="hidden" asp-for="Id" />

            <div class="row">

                <!-- CỘT TRÁI: Tiêu đề + Nội dung -->
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tiêu đề bài viết:</label>
                        <input asp-for="Title" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nội dung chi tiết:</label>
                        <textarea asp-for="Content" class="form-control" rows="12"></textarea>
                    </div>
                </div>

                <!-- CỘT PHẢI: Danh mục + Ảnh + Nút lưu -->
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Chuyên mục:</label>
                        <select asp-for="CategoryId" class="form-select"
                                asp-items="ViewBag.CategoryList">
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Ảnh hiện tại:</label><br>
                        <img src="@Model.ImageUrl"
                             id="currentImg"
                             class="img-fluid rounded"
                             style="max-height:150px; object-fit:cover; width:100%;"
                             onerror="this.style.display='none'"
                             alt="Ảnh hiện tại" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Upload ảnh mới (tuỳ chọn):</label>
                        <input type="file" name="uploadImage" class="form-control"
                               accept="image/*"
                               onchange="previewImage(this)" />
                        <small class="text-muted">Để trống nếu không muốn đổi ảnh.</small>
                    </div>

                    <!-- Giữ lại ImageUrl cũ nếu không upload mới -->
                    <input type="hidden" asp-for="ImageUrl" />

                    <div class="d-grid gap-2 mt-3">
                        <button type="submit" class="btn btn-warning text-dark">
                            <i class="bi bi-save"></i> Lưu thay đổi
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>
                    </div>
                </div>

            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        // Kích hoạt CKEditor cho ô nội dung
        ClassicEditor.create(document.querySelector('#Content'))
            .catch(error => console.error(error));

        // Xem trước ảnh mới trước khi upload
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('currentImg').src = e.target.result;
                    document.getElementById('currentImg').style.display = 'block';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}