@model CMS.Data.Entities.CategoryProduct
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm danh mục sản phẩm";
}

<div class="container mt-4" style="max-width:600px">
    <h2 class="text-primary mb-4">➕ THÊM DANH MỤC SẢN PHẨM</h2>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label class="form-label fw-bold">
                Tên danh mục <span class="text-danger">*</span>
            </label>
            <input asp-for="Name" class="form-control"
                   placeholder="VD: Áo thun" required />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="3"
                      placeholder="Mô tả ngắn về danh mục..."></textarea>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">💾 Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">↩ Quay lại</a>
        </div>
    </form>
</div>