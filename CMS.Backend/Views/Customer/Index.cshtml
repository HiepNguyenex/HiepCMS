@model IEnumerable<CMS.Data.Entities.Customer>
@{
    ViewData["Title"] = "Khách hàng";
    Layout = "_LayoutAdmin";

}
<div class="container mt-4">
    <h2 class="mb-4 text-info">👥 DANH SÁCH KHÁCH HÀNG</h2>
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr><th>#</th><th>Họ tên</th><th>Email</th><th>Điện thoại</th><th>Địa chỉ</th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.FullName</td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td>@item.Address</td>
                </tr>
            }
        </tbody>
    </table>
</div>