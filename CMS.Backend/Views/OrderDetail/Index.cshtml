@model IEnumerable<CMS.Data.Entities.OrderDetail>
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <h2 class="mb-4 text-secondary">📋 CHI TIẾT ĐƠN HÀNG</h2>
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Mã đơn hàng</th>
                            <th>Sản phẩm</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Chưa có chi tiết đơn hàng nào.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-3 align-middle">@item.Id</td>
                                    <td class="align-middle fw-semibold">#@item.OrderId</td>
                                    <td class="align-middle">@(item.Product?.Name ?? $"Sản phẩm #{item.ProductId}")</td>
                                    <td class="align-middle text-center">@item.Quantity</td>
                                    <td class="align-middle text-end">@item.UnitPrice.ToString("N0") đ</td>
                                    <td class="align-middle text-end fw-bold text-primary">@((item.Quantity * item.UnitPrice).ToString("N0")) đ</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>