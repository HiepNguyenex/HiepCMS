<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HiepCMS Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: #f8fafc;
            color: #1e293b;
        }

        /* Tối ưu hóa thanh cuộn */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        /* Sidebar Styling */
        .sidebar {
            min-height: 100vh;
            background-color: #0f172a; /* Slate 900 */
            color: #94a3b8;
            box-shadow: 4px 0 20px rgba(0, 0, 0, 0.05);
            z-index: 100;
        }

        .sidebar-brand-wrapper {
            background-color: #020617; /* Darker Slate */
            padding: 20px 15px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .sidebar-user-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            margin: 15px;
            padding: 12px;
        }

        .sidebar a {
            color: #94a3b8;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 24px;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.2s ease;
            position: relative;
        }

        .sidebar a i {
            font-size: 1.1rem;
            transition: transform 0.2s ease;
        }

        .sidebar a:hover {
            background-color: rgba(255, 255, 255, 0.04);
            color: #f8fafc;
        }

        .sidebar a:hover i {
            transform: scale(1.1);
        }

        .sidebar a.active {
            background: linear-gradient(90deg, rgba(59, 130, 246, 0.15) 0%, rgba(59, 130, 246, 0) 100%);
            color: #3b82f6; /* Modern Blue */
            font-weight: 600;
        }

        .sidebar a.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            background-color: #3b82f6;
            border-radius: 0 4px 4px 0;
            box-shadow: 2px 0 10px rgba(59, 130, 246, 0.5);
        }

        .section-title {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: #475569; /* Slate 600 */
            padding: 20px 24px 8px;
            font-weight: 700;
        }

        /* Giao diện Bảng & Thẻ dùng chung */
        .table-responsive {
            border-radius: 16px;
            box-shadow: 0 4px 18px rgba(0, 0, 0, 0.02);
            background: #ffffff;
            border: 1px solid #e2e8f0;
            overflow: hidden;
        }

        .table {
            margin-bottom: 0 !important;
        }

        .table thead th {
            background-color: #f8fafc !important;
            color: #475569 !important;
            font-weight: 700 !important;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 16px;
            border-bottom: 2px solid #e2e8f0;
        }

        .table tbody td {
            padding: 16px;
            vertical-align: middle;
            color: #334155;
            border-bottom: 1px solid #f1f5f9;
        }

        .btn {
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.85rem;
            padding: 8px 16px;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .btn-sm {
            padding: 6px 12px;
            font-size: 0.8rem;
        }

        .btn-primary {
            background-color: #3b82f6;
            border-color: #3b82f6;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);
        }
        .btn-primary:hover {
            background-color: #2563eb;
            border-color: #2563eb;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(59, 130, 246, 0.3);
        }

        .btn-success {
            background-color: #10b981;
            border-color: #10b981;
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
        }
        .btn-success:hover {
            background-color: #059669;
            border-color: #059669;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(16, 185, 129, 0.3);
        }

        .btn-warning {
            background-color: #f59e0b;
            border-color: #f59e0b;
            color: #ffffff !important;
            box-shadow: 0 4px 12px rgba(245, 158, 11, 0.2);
        }
        .btn-warning:hover {
            background-color: #d97706;
            border-color: #d97706;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(245, 158, 11, 0.3);
        }

        .form-select, .form-control {
            border-radius: 10px;
            border: 1px solid #cbd5e1;
            padding: 10px 14px;
            font-size: 0.9rem;
            transition: all 0.2s ease;
        }

        .form-select:focus, .form-control:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">

            <!-- SIDEBAR -->
            <nav class="col-md-3 col-lg-2 sidebar p-0">
                <div class="sidebar-brand-wrapper text-center">
                    <h5 class="text-white mb-0 fw-bold d-flex align-items-center justify-content-center gap-2">
                        <span class="fs-4">🛡️</span> HiepCMS Admin
                    </h5>
                    <small class="text-secondary small" style="font-size: 11px; letter-spacing: 0.5px;">MSSV: 2123110161</small>
                </div>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="sidebar-user-card text-center">
                        <div class="d-flex align-items-center justify-content-center mb-1">
                            <i class="bi bi-person-circle fs-4 me-2 text-primary"></i>
                            <span class="fw-semibold text-white text-truncate" style="max-width: 130px; font-size: 0.9rem;">
                                @User.FindFirst("FullName")?.Value
                            </span>
                        </div>
                        <span class="badge bg-primary bg-opacity-20 text-primary border border-primary border-opacity-10 py-1 px-2" style="font-size: 10px;">
                            @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                        </span>
                    </div>
                }
                <div class="mt-2 pb-5">
                    <a asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Bảng điều khiển
                    </a>

                    <div class="section-title">Tin tức</div>
                    <a asp-controller="Category" asp-action="Index">
                        <i class="bi bi-grid"></i> Danh mục tin
                    </a>
                    <a asp-controller="Post" asp-action="Index">
                        <i class="bi bi-file-earmark-post"></i> Bài viết
                    </a>

                    <div class="section-title">Sản phẩm</div>
                    <a asp-controller="CategoryProduct" asp-action="Index">
                        <i class="bi bi-tags"></i> Danh mục SP
                    </a>
                    <a asp-controller="Product" asp-action="Index">
                        <i class="bi bi-box-seam"></i> Sản phẩm
                    </a>

                    <div class="section-title">Triết lý hương</div>
                    <a asp-controller="Ingredient" asp-action="Index">
                        <i class="bi bi-flower1"></i> Nốt hương chính
                    </a>

                    <div class="section-title">Đơn hàng</div>
                    <a asp-controller="Customer" asp-action="Index">
                        <i class="bi bi-person-lines-fill"></i> Khách hàng
                    </a>
                    <a asp-controller="Order" asp-action="Index">
                        <i class="bi bi-cart3"></i> Đơn hàng
                    </a>
                    <a asp-controller="OrderDetail" asp-action="Index">
                        <i class="bi bi-list-check"></i> Chi tiết đơn
                    </a>

                    <div class="section-title">Hệ thống</div>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="User" asp-action="Index">
                            <i class="bi bi-people"></i> Thành viên
                        </a>
                    }
                    <a asp-controller="Account" asp-action="Logout">
                        <i class="bi bi-box-arrow-right text-danger"></i> Đăng xuất
                    </a>
                </div>
            </nav>

            <!-- NỘI DUNG CHÍNH -->
            <main class="col-md-9 col-lg-10 ms-sm-auto p-4">
                @RenderBody()
            </main>

        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            var path = window.location.pathname;
            $('.sidebar a').each(function() {
                var href = $(this).attr('href');
                if (href) {
                    if (path === href || (href !== '/' && path.startsWith(href))) {
                        $(this).addClass('active');
                    }
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>