@model IEnumerable<CMS.Data.Entities.Product>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>DANH SÁCH SẢN PHẨM</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Thêm sản phẩm
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Ảnh</th>
                <th>Tên sản phẩm</th>
                <th>Danh mục</th>
                <th>Giá</th>
                <th>Tồn kho</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>
                        <img src="@item.ImageUrl"
                             style="width:60px; height:60px; object-fit:cover; border-radius:6px;"
                             onerror="this.src='https://via.placeholder.com/60?text=No+Img'"
                             alt="@item.Name" />
                    </td>
                    <td class="fw-bold">@item.Name</td>
                    <td>
                        <span class="badge bg-secondary">
                            @(item.CategoryProduct?.Name ?? "Chưa phân loại")
                        </span>
                    </td>
                    <td class="text-success fw-bold">
                        @item.Price.ToString("N0") ₫
                    </td>
                    <td>
                        @if (item.StockQuantity > 10)
                        {
                            <span class="badge bg-success">@item.StockQuantity</span>
                        }
                        else if (item.StockQuantity > 0)
                        {
                            <span class="badge bg-warning text-dark">@item.StockQuantity</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Hết hàng</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i> Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger"
                               onclick="return confirm('Xóa sản phẩm này?')">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@* ───────── PAGINATION ───────── *@
@{
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}
@if (totalPages > 1)
{
    <nav aria-label="Phân trang sản phẩm">
        <ul class="pagination justify-content-center mt-3">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="?page=@(currentPage - 1)&pageSize=10" tabindex="-1">‹</a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="?page=@i&pageSize=10">@i</a>
                </li>
            }
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" href="?page=@(currentPage + 1)&pageSize=10">›</a>
            </li>
        </ul>
        <p class="text-center text-muted small mb-0">
            Trang @currentPage / @totalPages (tổng số @ViewBag.TotalItems sản phẩm)
        </p>
    </nav>
}