@model CMS.Data.Entities.Product
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Sửa sản phẩm";
}

<div class="card shadow">
    <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="bi bi-pencil-square"></i> SỬA SẢN PHẨM</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">

            <!-- ⚠️ BẮT BUỘC: giữ Id -->
            <input type="hidden" asp-for="Id" />

            <div class="row">

                <!-- CỘT TRÁI -->
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên sản phẩm:</label>
                        <input asp-for="Name" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả:</label>
                        <textarea asp-for="Description" class="form-control"
                                  rows="5"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Giá bán (₫):</label>
                            <input asp-for="Price" class="form-control"
                                   type="number" min="0" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Số lượng tồn kho:</label>
                            <input asp-for="StockQuantity" class="form-control"
                                   type="number" min="0" />
                        </div>
                    </div>
                </div>

                <!-- CỘT PHẢI -->
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Danh mục sản phẩm:</label>
                        <select asp-for="CategoryProductId" class="form-select"
                                asp-items="ViewBag.CategoryProductList">
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Ảnh hiện tại:</label><br>
                        <img src="@Model.ImageUrl"
                             id="currentImg"
                             class="img-fluid rounded"
                             style="max-height:150px; object-fit:cover; width:100%;"
                             onerror="this.style.display='none'"
                             alt="Ảnh hiện tại" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Upload ảnh mới (tuỳ chọn):</label>
                        <input type="file" name="uploadImage" class="form-control"
                               accept="image/*"
                               onchange="previewImage(this)" />
                        <small class="text-muted">Để trống nếu không muốn đổi ảnh.</small>
                    </div>

                    <!-- Giữ lại ImageUrl cũ nếu không upload mới -->
                    <input type="hidden" asp-for="ImageUrl" />

                    <div class="d-grid gap-2 mt-3">
                        <button type="submit" class="btn btn-warning text-dark">
                            <i class="bi bi-save"></i> Lưu thay đổi
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>
                    </div>
                </div>

            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('currentImg').src = e.target.result;
                    document.getElementById('currentImg').style.display = 'block';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}